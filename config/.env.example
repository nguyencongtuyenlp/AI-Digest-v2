# ── Notion ──────────────────────────────────────────
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Telegram Bot ────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=-1001234567890
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_THREAD_ID=
TELEGRAM_GITHUB_THREAD_ID=
TELEGRAM_FACEBOOK_THREAD_ID=

# ── Telethon (userbot – đọc channels) ──────────────
TELETHON_API_ID=12345678
TELETHON_API_HASH=abcdef0123456789abcdef0123456789
TELETHON_SESSION_NAME=digest_session

# ── Telegram channels to monitor ────────────────────
# Comma-separated list of channel usernames (without @)
TELEGRAM_CHANNELS=aivietnam,MLVietnam,binhdanhocai,ai_mastering_vn,nghienai

# ── Gather / source config ──────────────────────────
# RSS chính sẽ lấy theo danh sách curated trong source_catalog.py
GATHER_RSS_HOURS=72
DDG_MAX_RESULTS_PER_QUERY=3

# Hacker News / Reddit community signals
HN_ENABLED=1
HN_MAX_ITEMS=8
REDDIT_ENABLED=1
REDDIT_SUBREDDITS=LocalLLaMA,MachineLearning,OpenAI,Anthropic,singularity
REDDIT_MAX_POSTS_PER_SUBREDDIT=2

# GitHub repo / tool / framework signals
GITHUB_ENABLED=1
GITHUB_TOKEN=
GITHUB_MAX_ORG_REPOS=4
GITHUB_MAX_RELEASES_PER_REPO=1
GITHUB_MAX_SEARCH_RESULTS=4
GITHUB_WATCHLIST_ORGS=
GITHUB_WATCHLIST_REPOS=
# Dùng || để ngăn cách query nếu điền qua env
GITHUB_SEARCH_QUERIES=

# Manual social signals
# Manual social signals, bao gồm Facebook post/group/page mà team muốn đưa vào topic riêng.
ENABLE_SOCIAL_SIGNALS=0
SOCIAL_SIGNAL_INBOX_FILE=/Users/quangdang/Projects/daily-digest-agent/config/social_signal_inbox.txt
ENABLE_FACEBOOK_AUTO=1
FACEBOOK_AUTO_TARGETS_FILE=/Users/quangdang/Projects/daily-digest-agent/config/facebook_auto_targets.txt
FACEBOOK_AUTO_MAX_TARGETS=12
FACEBOOK_AUTO_POSTS_PER_TARGET=2
FACEBOOK_AUTO_HEADLESS=1
FACEBOOK_CHROME_EXECUTABLE=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
FACEBOOK_CHROME_PROFILE_DIR=/Users/quangdang/Projects/daily-digest-agent/config/facebook_chrome_profile
FACEBOOK_STORAGE_STATE_FILE=/Users/quangdang/Projects/daily-digest-agent/config/facebook_storage_state.json
FACEBOOK_DISCOVERY_ENABLED=1
FACEBOOK_DISCOVERY_CACHE_FILE=/Users/quangdang/Projects/daily-digest-agent/config/facebook_discovered_sources.json
FACEBOOK_DISCOVERY_REFRESH_HOURS=24
FACEBOOK_DISCOVERY_MAX_ACTIVE_SOURCES=12
FACEBOOK_DISCOVERY_MAX_CANDIDATES_PER_RUN=20
FACEBOOK_ALLOW_PROFILE_SOURCES=1
FACEBOOK_FORCE_NEWEST_FIRST=1
FACEBOOK_MAX_POST_AGE_HOURS=72
FACEBOOK_REVIEW_MAX_POST_AGE_HOURS=168

# Watchlist seed: URL trực tiếp hoặc query từ file / env
WATCHLIST_SEEDS_FILE=/Users/quangdang/Projects/daily-digest-agent/config/watchlist_seeds.txt
WATCHLIST_URLS=
# Dùng || để ngăn cách query nếu điền qua env
WATCHLIST_QUERIES=

# Nơi lưu báo cáo markdown sau mỗi run
DIGEST_REPORTS_DIR=reports

# UI local control panel
DIGEST_UI_HOST=127.0.0.1
DIGEST_UI_PORT=8787

# Profile cho main.py / launchd:
# - publish: chế độ mặc định
# - grok_smart: mở rộng Grok shortlist/scout để so output mạnh hơn
DIGEST_RUN_PROFILE=publish

# ── LLM config ──────────────────────────────────────
# Mặc định khuyên dùng 32B trên máy 48GB để cân bằng chất lượng và tính ổn định.
# 14B để fallback nếu cần.
MLX_MODEL=mlx-community/Qwen2.5-32B-Instruct-4bit
MLX_FALLBACK_MODEL=mlx-community/Qwen2.5-14B-Instruct-4bit
MLX_SMART_MODEL=
MLX_AUTO_FALLBACK=1

# ── Optional xAI / Grok reranker ────────────────────
# Nếu có XAI_API_KEY, hệ có thể dùng Grok để rerank shortlist bài nào xứng đáng lên main brief.
# Mặc định bật tự động khi key tồn tại; đặt =0 nếu muốn tắt.
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
GROK_DELIVERY_JUDGE_ENABLED=1
GROK_DELIVERY_MODEL=grok-4-1-fast-non-reasoning
GROK_DELIVERY_MAX_ARTICLES=10
GROK_DELIVERY_TIMEOUT_SECONDS=35
GROK_PREFILTER_ENABLED=1
GROK_PREFILTER_MAX_ARTICLES=18
GROK_FINAL_EDITOR_ENABLED=1
GROK_FINAL_EDITOR_MAX_ARTICLES=8
GROK_NEWS_COPY_ENABLED=1
GROK_NEWS_COPY_MAX_ARTICLES=18
GROK_FACEBOOK_SCORE_ENABLED=1
GROK_FACEBOOK_MAX_ARTICLES=8
GROK_SOURCE_GAP_ENABLED=1
GROK_SOURCE_GAP_MAX_ARTICLES=12
GROK_SCOUT_ENABLED=1
GROK_SCOUT_MODEL=grok-4-1-fast-reasoning
GROK_SCOUT_MAX_QUERIES=2
GROK_SCOUT_MAX_ARTICLES=6
GROK_SCOUT_MIN_OFFICIAL_ARTICLES=8
GROK_SCOUT_MIN_OFFICIAL_PLUS_MEDIA=10
GROK_SCOUT_MIN_NON_GITHUB_ARTICLES=18
GROK_X_SCOUT_ENABLED=1
GROK_X_SCOUT_MAX_QUERIES=2
GROK_X_SCOUT_MAX_ARTICLES=4
# Optional: comma-separated X handles, without @. Leave blank to use the curated defaults in code.
GROK_X_SCOUT_ALLOWED_HANDLES=
GROK_X_SCOUT_EXCLUDED_HANDLES=

# Temporal snapshots để debug mỗi run dễ hơn
TEMPORAL_SNAPSHOTS_ENABLED=1
TEMPORAL_SNAPSHOT_DIR=reports/temporal_snapshots

# Runtime artifact cleanup để repo không phình vì report/log/snapshot cũ
DIGEST_ARTIFACT_CLEANUP_ENABLED=1
DIGEST_ARTIFACT_ARCHIVE_DIR=.runtime_archive
